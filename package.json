{
  "name": "tmr-app",
  "version": "1.0.0",
  "description": "Electron app with Vue, Tailwind, and TypeScript",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron:ts\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron:ts": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:electron": "wait-on tcp:5173 file:dist-electron/main.js && electronmon .",
    "icon:mac": "zsh scripts/generate-mac-icon.sh",
    "build": "vue-tsc --noEmit && vite build && tsc -p tsconfig.electron.json",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "release:mac": "zsh scripts/upload-mac-release.sh",
    "dist:win": "npm run build && electron-builder --win",
    "preview": "vite preview"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "electronmon": "^2.0.4",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vue-tsc": "^3.2.6",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "vue": "^3.5.22"
  },
  "build": {
    "appId": "com.senghong.tmrapp",
    "productName": "TMR App",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "asar": true,
    "mac": {
      "icon": "build/mac/icon.icns",
      "artifactName": "TMR-App-mac.${ext}",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "artifactName": "TMR-App-setup.${ext}",
      "target": [
        "nsis"
      ]
    }
  }
}
